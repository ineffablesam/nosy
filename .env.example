SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
# USER token (xoxp-) with the `search:read` scope — required for Slack's
# Real-Time Search API (assistant.search.context). Get it by adding
# `search:read` under OAuth & Permissions → User Token Scopes and reinstalling.
# Leave blank to disable RTS; Nosy falls back to its cached memory.
SLACK_USER_TOKEN=
SOCKET_MODE=true
ANTHROPIC_API_KEY=your-synterolink-key
ANTHROPIC_BASE_URL=https://api.synterolink.com
ANTHROPIC_MODEL=claude-sonnet-4-6
# Model for DM replies (respond.ts). Haiku = fast/cheap for casual texting.
# Thread analysis (analyze.ts) uses ANTHROPIC_MODEL (Sonnet) above.
DM_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=your-synterolink-key
OPENAI_MODEL=gpt-5.4
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
RECEIPT_STALE_HOURS=24
OBITUARY_SILENCE_HOURS=4
# Milliseconds of silence after the last message before Nosy analyzes a thread.
# Lets a seeder burst settle so Claude sees the full story in one shot.
ANALYSIS_DEBOUNCE_MS=8000
PORT=3000
# Set to false to disable meme generation in DMs
MEMES_ENABLED=true
# Set to false to disable Slack Real-Time Search grounding in DM replies.
RTS_ENABLED=true
